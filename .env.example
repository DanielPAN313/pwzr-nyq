# Local development defaults. Copy to .env only if you need to override values.
PORT=4174

# Optional local MySQL. If omitted, the local mirror uses its built-in demo data path.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=nyq
MYSQL_USER=nyq
MYSQL_PASSWORD=change_app_password

# Optional OpenAI-compatible settings for legacy H5 modules.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_BASE_URL=https://api.openai.com/v1
