page {
  min-height: 100vh;
  color: #102016;
  background: #f4f7f2;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(219, 228, 216, 0.9);
  border-radius: 20rpx;
  background: #ffffff;
}

.muted {
  color: #6f7c72;
}

.primary {
  color: #ffffff;
  background: #12824f;
}

.state-panel {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(219, 228, 216, 0.95);
  border-radius: 20rpx;
  background: #ffffff;
}

.state-panel.warning {
  border-color: rgba(255, 190, 92, 0.45);
  background: #fffaf0;
}

.state-panel.empty {
  background: #fbfdf9;
}

.state-title {
  color: #102016;
  font-size: 30rpx;
  font-weight: 900;
}

.state-text {
  color: #6f7c72;
  font-size: 26rpx;
  line-height: 1.5;
}

.state-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 6rpx;
}

.state-actions button {
  flex: 1;
  min-width: 0;
}

.secondary {
  color: #12824f;
  background: #eef6ed;
}
