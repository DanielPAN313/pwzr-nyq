<view class="page">
  <view class="section">
    <view class="page-title">发起球局</view>
    <text wx:if="{{loading}}" class="muted">正在加载场馆...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}</text>
    <text wx:else class="muted">创建后会出现在球局列表，报名和支付沿用现有订单流程。</text>
  </view>

  <view wx:if="{{error}}" class="state-panel warning">
    <text class="state-title">场馆数据暂时不可用</text>
    <text class="state-text">{{error}} 可以重新加载场馆，或者先去订场页确认场馆数据。</text>
    <view class="state-actions">
      <button class="primary small" bindtap="retryLoadVenues">重试加载</button>
      <button class="secondary small" bindtap="goVenues">去订场页</button>
    </view>
  </view>

  <view class="section summary-panel">
    <view class="section-title">发布预览</view>
    <text class="summary-title">{{title || "未命名球局"}}</text>
    <text class="summary-muted">{{selectedVenueText}}</text>
    <text class="summary-muted">{{timeRangeText}}</text>
    <view class="summary-grid">
      <view wx:for="{{summaryCards}}" wx:key="label" class="summary-card">
        <text class="summary-value">{{item.value}}</text>
        <text class="summary-label">{{item.label}}</text>
      </view>
    </view>
    <text class="submit-hint">{{submitHint}}</text>
    <view class="validation-list">
      <view wx:for="{{validationItems}}" wx:key="key" class="validation-item {{item.ok ? 'is-ok' : 'is-pending'}}">
        <text class="validation-dot">{{item.ok ? "✓" : "!"}}</text>
        <text class="validation-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <view class="section form-panel">
    <label class="field">
      <text class="field-label">标题</text>
      <input class="field-input" value="{{title}}" bindinput="updateTitle" placeholder="例如：周五晚五人制足球" />
    </label>

    <label class="field">
      <text class="field-label">运动</text>
      <picker range="{{sportOptions}}" range-key="label" value="{{sportIndex}}" bindchange="changeSport">
        <view class="picker-value">{{sportOptions[sportIndex].label}}</view>
      </picker>
    </label>

    <label class="field">
      <text class="field-label">场馆</text>
      <picker range="{{venues}}" range-key="name" value="{{venueIndex}}" bindchange="changeVenue">
        <view class="picker-value">{{selectedVenueText}}</view>
      </picker>
    </label>

    <label class="field">
      <text class="field-label">日期</text>
      <picker mode="date" value="{{date}}" start="{{minDate}}" bindchange="changeDate">
        <view class="picker-value">{{date}}</view>
      </picker>
    </label>

    <label class="field">
      <text class="field-label">开始时间</text>
      <picker mode="time" value="{{startTime}}" bindchange="changeStartTime">
        <view class="picker-value">{{startTime}}</view>
      </picker>
    </label>

    <label class="field">
      <text class="field-label">时长</text>
      <picker range="{{durationOptions}}" range-key="label" value="{{durationIndex}}" bindchange="changeDuration">
        <view class="picker-value">{{durationOptions[durationIndex].label}}</view>
      </picker>
    </label>

    <label class="field">
      <text class="field-label">人数</text>
      <input class="field-input" type="number" value="{{capacity}}" bindinput="updateCapacity" />
    </label>

    <label class="field">
      <text class="field-label">人均费用</text>
      <input class="field-input" type="digit" value="{{fee}}" bindinput="updateFee" />
    </label>

    <label class="field">
      <text class="field-label">备注</text>
      <textarea class="field-textarea" value="{{notes}}" bindinput="updateNotes" placeholder="补充水平、装备、集合方式等信息" />
    </label>
  </view>

  <button class="primary submit-button" disabled="{{!canSubmit}}" bindtap="submitGame">
    {{submitting ? "发布中" : "发布球局"}}
  </button>
</view>
