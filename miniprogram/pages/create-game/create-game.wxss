.page-title,
.section-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 34rpx;
  font-weight: 850;
}

.summary-panel {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.summary-title {
  color: #102016;
  font-size: 34rpx;
  font-weight: 900;
}

.summary-muted {
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.45;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 6rpx;
}

.summary-card {
  min-height: 96rpx;
  padding: 14rpx;
  border-radius: 8rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(20, 32, 50, 0.08);
}

.summary-value {
  display: block;
  color: #102016;
  font-size: 26rpx;
  font-weight: 850;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 750;
}

.submit-hint {
  padding: 16rpx;
  border-left: 6rpx solid #12b76a;
  border-radius: 8rpx;
  background: #ecfdf3;
  color: #067647;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 750;
}

.validation-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10rpx;
  margin-top: 6rpx;
}

.validation-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: #f8fafc;
}

.validation-item.is-ok {
  background: #ecfdf3;
}

.validation-item.is-pending {
  background: #fff7ed;
}

.validation-dot {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #f97316;
  font-size: 22rpx;
  font-weight: 900;
}

.validation-item.is-ok .validation-dot {
  background: #12824f;
}

.validation-text {
  color: #334138;
  font-size: 24rpx;
  line-height: 1.4;
}

.form-panel {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.field-label {
  color: #102016;
  font-size: 26rpx;
  font-weight: 800;
}

.field-input,
.picker-value,
.field-textarea {
  min-height: 78rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #eef6ed;
  color: #102016;
  font-size: 28rpx;
  box-sizing: border-box;
}

.field-textarea {
  width: 100%;
  min-height: 150rpx;
}

.submit-button {
  margin-top: 8rpx;
  min-height: 88rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 850;
}
