<view class="page">
  <view class="credit-hero">
    <text class="hero-label">当前信用分</text>
    <text class="score">{{score}}</text>
    <text wx:if="{{loading}}" class="hero-hint">正在加载信用账户...</text>
    <text wx:elif="{{error}}" class="hero-hint">{{error}}，已显示本地兜底数据。</text>
    <text wx:else class="hero-hint">{{level}}</text>
  </view>

  <view class="section metric-grid">
    <view class="metric">
      <text class="metric-value">{{played}}</text>
      <text class="muted">参与场次</text>
    </view>
    <view class="metric">
      <text class="metric-value">{{checkedIn}}</text>
      <text class="muted">到场核销</text>
    </view>
    <view class="metric">
      <text class="metric-value">{{noShows}}</text>
      <text class="muted">爽约次数</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">信用记录</view>
    <view wx:for="{{events}}" wx:key="title" class="credit-row">
      <view>
        <text class="event-title">{{item.title}}</text>
        <text class="muted">{{item.note}}</text>
        <text class="muted">{{item.timeText}}</text>
      </view>
      <text class="score-delta">{{item.scoreText}}</text>
    </view>
  </view>
</view>
