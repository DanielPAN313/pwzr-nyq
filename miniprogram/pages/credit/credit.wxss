.credit-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 34rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: #064327;
}

.hero-label,
.hero-hint {
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
}

.score {
  font-size: 78rpx;
  font-weight: 900;
  line-height: 1;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.metric {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.metric-value {
  color: #102016;
  font-size: 36rpx;
  font-weight: 900;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 850;
}

.credit-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(219, 228, 216, 0.9);
}

.credit-row:last-child {
  border-bottom: 0;
}

.event-title {
  display: block;
  margin-bottom: 6rpx;
  color: #102016;
  font-size: 28rpx;
  font-weight: 800;
}

.score-delta {
  color: #12824f;
  font-size: 32rpx;
  font-weight: 900;
}
