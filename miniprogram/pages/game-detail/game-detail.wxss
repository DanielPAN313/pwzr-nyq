.page-title,
.section-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 34rpx;
  font-weight: 850;
}

.detail-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 34rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: #064327;
}

.detail-title {
  font-size: 42rpx;
  font-weight: 900;
}

.detail-status {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #083923;
  background: #d7f36a;
  font-size: 24rpx;
  font-weight: 850;
}

.detail-muted {
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-value {
  color: #102016;
  font-size: 30rpx;
  font-weight: 900;
}

.player-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(219, 228, 216, 0.9);
}

.player-row:last-child {
  border-bottom: 0;
}

.player-name {
  display: block;
  margin-bottom: 6rpx;
  color: #102016;
  font-size: 28rpx;
  font-weight: 850;
}

.player-status {
  color: #12824f;
  font-size: 26rpx;
  font-weight: 850;
}

.review-panel {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.player-tags {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.review-status {
  color: #6f7c72;
  font-size: 24rpx;
  font-weight: 750;
}
