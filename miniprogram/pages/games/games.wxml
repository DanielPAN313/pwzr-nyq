<view class="page">
  <view class="section">
    <view class="page-title">附近球局</view>
    <text wx:if="{{loading}}" class="muted">正在加载球局...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}，已显示本地兜底球局。</text>
    <text wx:elif="{{empty}}" class="muted">没有找到匹配球局，可以换个关键词或运动类型。</text>
    <text wx:else class="muted">按球局、场馆或运动类型快速找人。</text>
    <input
      class="search-input"
      placeholder="搜索球局或场馆"
      value="{{query}}"
      bindinput="onSearchInput"
    />
    <view class="filter-row">
      <button
        wx:for="{{sportFilters}}"
        wx:key="value"
        class="filter-chip {{activeSport === item.value ? 'is-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="changeSport"
      >
        {{item.label}}
      </button>
    </view>
    <button class="primary small create-button" bindtap="createGame">发起球局</button>
  </view>

  <view wx:if="{{error}}" class="state-panel warning">
    <text class="state-title">球局数据暂时没连上</text>
    <text class="state-text">当前展示的是本地兜底球局。确认后端运行后可以重试，或者先发起一场球局继续开发。</text>
    <view class="state-actions">
      <button class="primary small" bindtap="retryLoadGames">重试加载</button>
      <button class="secondary small" bindtap="createGame">发起球局</button>
    </view>
  </view>

  <view wx:elif="{{empty}}" class="state-panel empty">
    <text class="state-title">没有匹配的球局</text>
    <text class="state-text">可以清空筛选重新找，或者直接发起一个新球局。</text>
    <view class="state-actions">
      <button class="primary small" bindtap="resetFilters">清空筛选</button>
      <button class="secondary small" bindtap="createGame">发起球局</button>
    </view>
  </view>

  <view wx:for="{{games}}" wx:key="title" class="section game-card" bindtap="openGame" data-id="{{item.id}}">
    <text class="card-title">{{item.title}}</text>
    <text class="muted">{{item.time}} · {{item.venueName}} · {{item.fee}}</text>
    <view class="card-row">
      <text class="status">{{item.status}}</text>
      <button
        class="primary small"
        disabled="{{!item.canJoin || joiningId === item.id}}"
        catchtap="joinGame"
        data-id="{{item.id}}"
      >
        {{joiningId === item.id ? "报名中" : item.actionText}}
      </button>
    </view>
  </view>
</view>
