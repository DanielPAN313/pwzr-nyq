<view class="page">
  <view class="section page-hero">
    <text class="page-kicker">OPEN MATCHES</text>
    <view class="page-title">附近球局</view>
    <text wx:if="{{loading}}" class="muted">正在加载球局...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}，已显示本地兜底球局。</text>
    <text wx:elif="{{empty}}" class="muted">暂时没有可报名球局。</text>
    <text wx:else class="muted">已接入真实球局列表，后续继续补报名和支付。</text>
    <view class="filter-row">
      <text class="pill dark">可报名</text>
      <text class="pill">今晚</text>
      <text class="pill">离我近</text>
    </view>
  </view>

  <view wx:for="{{games}}" wx:key="title" class="section game-card">
    <view class="match-head">
      <view>
        <text class="card-title">{{item.title}}</text>
        <text class="muted">{{item.time}} · {{item.venueName}}</text>
      </view>
      <text class="status-chip">{{item.status}}</text>
    </view>
    <view class="match-meta">
      <text class="meta-item">{{item.fee}}</text>
      <text class="meta-item">实名报名</text>
      <text class="meta-item">到场核销</text>
    </view>
    <view class="card-row">
      <view class="players">
        <text class="player-dot"></text>
        <text class="player-dot"></text>
        <text class="player-dot empty"></text>
        <text class="players-text">{{item.status}}</text>
      </view>
      <button
        class="primary small join-button"
        disabled="{{!item.canJoin || joiningId === item.id}}"
        bindtap="joinGame"
        data-id="{{item.id}}"
      >
        {{joiningId === item.id ? "报名中" : item.actionText}}
      </button>
    </view>
  </view>
</view>
