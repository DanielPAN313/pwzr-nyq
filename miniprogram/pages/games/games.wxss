.page-title,
.card-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 34rpx;
  font-weight: 850;
}

.game-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.search-input {
  box-sizing: border-box;
  width: 100%;
  height: 72rpx;
  margin-top: 18rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(20, 32, 50, 0.12);
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 28rpx;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.filter-chip {
  min-width: 112rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(20, 32, 50, 0.12);
  border-radius: 8rpx;
  background: #ffffff;
  color: #334155;
  font-size: 24rpx;
  line-height: 56rpx;
}

.filter-chip.is-active {
  border-color: #12b76a;
  background: #ecfdf3;
  color: #067647;
  font-weight: 800;
}

.status {
  color: #0b6b3e;
  font-size: 30rpx;
  font-weight: 800;
}

.small {
  min-width: 150rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
}
