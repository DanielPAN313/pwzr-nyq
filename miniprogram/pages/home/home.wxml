<view class="page">
  <view class="hero">
    <text class="eyebrow">南京样板区</text>
    <text class="title">开球，去宁约球</text>
    <text class="subtitle">找附近球局、抢黄金场地、报名支付、到场核销。</text>
  </view>

  <view class="stat-grid">
    <view wx:for="{{statCards}}" wx:key="label" class="stat-card stat-{{item.tone}}">
      <text class="stat-value">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">常用入口</view>
    <view class="quick-grid">
      <button
        wx:for="{{quickActions}}"
        wx:key="label"
        class="quick-card"
        bindtap="switchTab"
        data-target="{{item.target}}"
      >
        {{item.label}}
      </button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">待处理事项</view>
    <text wx:if="{{loading}}" class="muted">正在加载首页数据...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}，已显示本地兜底内容。</text>
    <text wx:elif="{{todoItems.length === 0}}" class="muted">暂无待处理事项，可以去找球局或订场。</text>
    <view
      wx:for="{{todoItems}}"
      wx:key="title"
      class="todo-card"
      bindtap="openTarget"
      data-target="{{item.target}}"
      data-tab="{{item.tab}}"
    >
      <view>
        <text class="todo-title">{{item.title}}</text>
        <text class="todo-text">{{item.text}}</text>
      </view>
      <text class="action-text">{{item.actionText}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">推荐场馆</view>
    <text wx:if="{{recommendedVenues.length === 0}}" class="muted">暂无推荐场馆。</text>
    <view
      wx:for="{{recommendedVenues}}"
      wx:key="id"
      class="recommend-row"
      bindtap="openTarget"
      data-target="{{item.target}}"
    >
      <view>
        <text class="recommend-title">{{item.name}}</text>
        <text class="recommend-meta">{{item.meta}}</text>
      </view>
      <text class="action-text">查看</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">推荐球局</view>
    <text wx:if="{{recommendedGames.length === 0}}" class="muted">暂无推荐球局。</text>
    <view
      wx:for="{{recommendedGames}}"
      wx:key="id"
      class="recommend-row"
      bindtap="openTarget"
      data-target="{{item.target}}"
    >
      <view>
        <text class="recommend-title">{{item.title}}</text>
        <text class="recommend-meta">{{item.meta}}</text>
      </view>
      <text class="action-text">查看</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">今日概览</view>
    <text class="muted">{{summary}}</text>
  </view>
</view>
