<view class="page">
  <view class="hero">
    <text class="eyebrow">南京样板区</text>
    <text class="title">开球，去宁约球</text>
    <text class="subtitle">找附近球局、抢黄金场地、报名支付、到场核销。</text>
  </view>

  <view class="section">
    <view class="section-title">常用入口</view>
    <view class="quick-grid">
      <button
        wx:for="{{quickActions}}"
        wx:key="label"
        class="quick-card"
        bindtap="switchTab"
        data-target="{{item.target}}"
      >
        {{item.label}}
      </button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">下一步开发</view>
    <text wx:if="{{loading}}" class="muted">正在加载首页数据...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}，已显示本地兜底内容。</text>
    <text wx:else class="muted">{{summary}}</text>
  </view>
</view>
