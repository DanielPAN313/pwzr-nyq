.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.location {
  display: block;
}

.location {
  color: rgba(247, 251, 245, 0.58);
  font-size: 24rpx;
  font-weight: 800;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 88rpx;
  margin-bottom: 24rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(216, 255, 62, 0.12);
  border-radius: 28rpx;
  background: #101b15;
  box-sizing: border-box;
}

.search-icon {
  color: #d8ff3e;
  font-size: 34rpx;
  font-weight: 900;
}

.search-text {
  flex: 1;
  color: rgba(247, 251, 245, 0.52);
  font-size: 26rpx;
  font-weight: 700;
}

.search-filter {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #10200f;
  background: #d8ff3e;
  font-size: 23rpx;
  font-weight: 900;
}

.hero {
  margin-bottom: 22rpx;
}

.court-panel {
  position: relative;
  min-height: 430rpx;
  padding: 30rpx;
  border-radius: 38rpx;
  background: linear-gradient(145deg, #13241a 0%, #0b3d27 48%, #0f8a4f 100%);
  box-shadow: 0 34rpx 72rpx rgba(0, 0, 0, 0.36);
  overflow: hidden;
  box-sizing: border-box;
}

.court-panel::before {
  content: "";
  position: absolute;
  inset: 128rpx 42rpx 34rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.44);
  border-radius: 26rpx;
}

.court-panel::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 128rpx;
  bottom: 34rpx;
  width: 3rpx;
  background: rgba(255, 255, 255, 0.38);
}

.court-glow {
  position: absolute;
  right: -96rpx;
  top: -110rpx;
  width: 310rpx;
  height: 310rpx;
  border-radius: 50%;
  background: rgba(216, 255, 62, 0.22);
  filter: blur(2rpx);
}

.court-line,
.court-net {
  position: absolute;
  left: 42rpx;
  right: 42rpx;
  height: 3rpx;
  background: rgba(255, 255, 255, 0.38);
}

.court-line-top {
  top: 230rpx;
}

.court-line-bottom {
  bottom: 118rpx;
}

.court-net {
  top: 286rpx;
  background: #d8ff3e;
  box-shadow: 0 0 26rpx rgba(216, 255, 62, 0.46);
}

.court-ball {
  position: absolute;
  right: 82rpx;
  top: 190rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #d8ff3e;
  box-shadow: 0 0 0 12rpx rgba(216, 255, 62, 0.16);
}

.court-copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.title {
  display: block;
  max-width: 520rpx;
  color: #ffffff;
  font-size: 62rpx;
  font-weight: 950;
  line-height: 1.02;
}

.subtitle {
  display: block;
  max-width: 470rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.55;
}

.date-strip {
  display: flex;
  gap: 14rpx;
  margin-bottom: 22rpx;
  overflow: hidden;
}

.date-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  min-height: 66rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: rgba(247, 251, 245, 0.72);
  background: #101b15;
  font-size: 25rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.date-pill.active {
  color: #10200f;
  background: #d8ff3e;
}

.feature-card {
  padding: 22rpx;
}

.feature-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.venue-card {
  display: flex;
  gap: 18rpx;
}

.venue-image {
  position: relative;
  flex-shrink: 0;
  width: 178rpx;
  min-height: 178rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #0f8a4f, #1b2b20);
  overflow: hidden;
}

.mini-court {
  position: absolute;
  inset: 24rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 18rpx;
}

.mini-court::before,
.mini-court::after {
  content: "";
  position: absolute;
  background: #d8ff3e;
}

.mini-court::before {
  left: 50%;
  top: 0;
  bottom: 0;
  width: 3rpx;
}

.mini-court::after {
  left: 0;
  right: 0;
  top: 50%;
  height: 3rpx;
}

.venue-info {
  flex: 1;
  min-width: 0;
}

.venue-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.price {
  color: #d8ff3e;
  font-size: 30rpx;
  font-weight: 950;
}

.book-button {
  flex-shrink: 0;
  min-width: 116rpx;
  min-height: 62rpx;
  border-radius: 999rpx;
  color: #10200f;
  background: #d8ff3e;
  font-size: 25rpx;
  font-weight: 950;
}

.update-card {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
