.hero {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 36rpx 28rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #064327, #12824f);
}

.eyebrow {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #083923;
  background: #d7f36a;
  font-size: 22rpx;
  font-weight: 700;
}

.title {
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.08;
}

.subtitle {
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
  line-height: 1.55;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.quick-card {
  min-height: 112rpx;
  border: 0;
  border-radius: 18rpx;
  color: #102016;
  background: #eef6ed;
  font-size: 30rpx;
  font-weight: 800;
}
