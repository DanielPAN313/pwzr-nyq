.hero {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 36rpx 28rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #064327, #12824f);
}

.eyebrow {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #083923;
  background: #d7f36a;
  font-size: 22rpx;
  font-weight: 700;
}

.title {
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.08;
}

.subtitle {
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
  line-height: 1.55;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.stat-card {
  min-height: 108rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(20, 32, 50, 0.08);
  border-radius: 8rpx;
  background: #f8fafc;
}

.stat-success {
  background: #ecfdf3;
}

.stat-info {
  background: #eff6ff;
}

.stat-warning {
  background: #fff7ed;
}

.stat-value {
  display: block;
  color: #102016;
  font-size: 36rpx;
  font-weight: 900;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 750;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.quick-card {
  min-height: 112rpx;
  border: 0;
  border-radius: 18rpx;
  color: #102016;
  background: #eef6ed;
  font-size: 30rpx;
  font-weight: 800;
}

.todo-card,
.recommend-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(219, 228, 216, 0.9);
}

.todo-card:first-of-type,
.recommend-row:first-of-type {
  border-top: 0;
  padding-top: 0;
}

.todo-title,
.recommend-title {
  display: block;
  color: #102016;
  font-size: 28rpx;
  font-weight: 850;
}

.todo-text,
.recommend-meta {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.45;
}

.action-text {
  flex-shrink: 0;
  color: #0b6b3e;
  font-size: 26rpx;
  font-weight: 850;
}
