.page-title {
  display: block;
  margin-bottom: 10rpx;
  color: #102016;
  font-size: 34rpx;
  font-weight: 850;
}

.tabs {
  display: flex;
  width: 100%;
  margin-bottom: 20rpx;
  white-space: nowrap;
}

.tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 150rpx;
  height: 58rpx;
  margin-right: 12rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(219, 228, 216, 0.95);
  border-radius: 999rpx;
  color: #5c6a61;
  font-size: 26rpx;
  font-weight: 800;
  background: #ffffff;
}

.tab.active {
  color: #ffffff;
  border-color: #12824f;
  background: #12824f;
}

.legal-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.legal-title {
  color: #102016;
  font-size: 34rpx;
  font-weight: 900;
}

.legal-meta {
  color: #12824f;
  font-size: 24rpx;
  font-weight: 850;
}

.legal-intro {
  color: #334138;
  font-size: 27rpx;
  line-height: 1.55;
}

.legal-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(219, 228, 216, 0.9);
}

.legal-index {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
  background: #12824f;
}

.legal-text {
  flex: 1;
  color: #5c6a61;
  font-size: 26rpx;
  line-height: 1.5;
}
