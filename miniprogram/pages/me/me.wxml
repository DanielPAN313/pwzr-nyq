<view class="page">
  <view class="profile">
    <text class="avatar">NYQ</text>
    <text class="name">{{profileName}}</text>
    <text wx:if="{{loading}}" class="muted">正在加载我的数据...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}，已显示本地兜底资料。</text>
    <text wx:else class="muted">{{profileHint}}</text>
  </view>

  <view class="section">
    <view wx:for="{{items}}" wx:key="label" class="menu-row" bindtap="openMenu" data-target="{{item.target}}">
      <text>{{item.label}}</text>
      <text class="muted">{{item.value}} ›</text>
    </view>
  </view>
</view>
