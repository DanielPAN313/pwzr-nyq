<view class="page">
  <view class="profile">
    <view class="profile-top">
      <text class="avatar">NYQ</text>
      <text class="page-kicker">PLAYER CARD</text>
    </view>
    <text class="name">{{profileName}}</text>
    <text wx:if="{{loading}}" class="profile-hint">正在加载我的数据...</text>
    <text wx:elif="{{error}}" class="profile-hint">{{error}}，已显示本地兜底资料。</text>
    <text wx:else class="profile-hint">{{profileHint}}</text>
    <view class="profile-stats">
      <view>
        <text class="stat-value">100</text>
        <text class="stat-label">信用分</text>
      </view>
      <view>
        <text class="stat-value">0</text>
        <text class="stat-label">待核销</text>
      </view>
      <view>
        <text class="stat-value">0</text>
        <text class="stat-label">本周局</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view wx:for="{{items}}" wx:key="label" class="menu-row" bindtap="openMenu" data-target="{{item.target}}">
      <view>
        <text class="menu-label">{{item.label}}</text>
        <text class="muted">查看详情</text>
      </view>
      <text class="menu-value">{{item.value}} ›</text>
    </view>
  </view>
</view>
