<view class="page">
  <view class="profile">
    <text class="avatar">NYQ</text>
    <text class="name">{{profileName}}</text>
    <text wx:if="{{loading}}" class="muted">正在加载我的数据...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}，已显示本地兜底资料。</text>
    <text wx:else class="muted">{{profileHint}}</text>
  </view>

  <view class="stat-grid">
    <view wx:for="{{statCards}}" wx:key="label" class="stat-card stat-{{item.tone}}">
      <text class="stat-value">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <view wx:for="{{menuSections}}" wx:key="title" class="section menu-section">
    <view class="section-title">{{item.title}}</view>
    <view
      wx:for="{{item.items}}"
      wx:for-item="entry"
      wx:key="label"
      class="menu-row"
      bindtap="openMenu"
      data-target="{{entry.target}}"
    >
      <view class="menu-main">
        <text class="menu-label">{{entry.label}}</text>
        <text class="menu-hint">{{entry.hint}}</text>
      </view>
      <text class="menu-value">{{entry.value}} ›</text>
    </view>
  </view>
</view>
