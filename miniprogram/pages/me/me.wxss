.profile {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: #064327;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  color: #083923;
  background: #d7f36a;
  font-size: 28rpx;
  font-weight: 900;
}

.name {
  font-size: 36rpx;
  font-weight: 850;
}

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  border-bottom: 1rpx solid rgba(219, 228, 216, 0.9);
  font-size: 30rpx;
  font-weight: 700;
}

.menu-row:last-child {
  border-bottom: 0;
}
