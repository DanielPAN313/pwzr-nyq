.profile {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: #064327;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  color: #083923;
  background: #d7f36a;
  font-size: 28rpx;
  font-weight: 900;
}

.name {
  font-size: 36rpx;
  font-weight: 850;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.stat-card {
  min-height: 116rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(20, 32, 50, 0.08);
}

.stat-warning {
  background: #fff7ed;
}

.stat-success {
  background: #ecfdf3;
}

.stat-info {
  background: #eff6ff;
}

.stat-value {
  display: block;
  color: #102016;
  font-size: 36rpx;
  font-weight: 900;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 750;
}

.menu-section {
  margin-bottom: 18rpx;
}

.section-title {
  margin-bottom: 8rpx;
  color: #102016;
  font-size: 30rpx;
  font-weight: 850;
}

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 104rpx;
  border-bottom: 1rpx solid rgba(219, 228, 216, 0.9);
}

.menu-row:last-child {
  border-bottom: 0;
}

.menu-main {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 6rpx;
}

.menu-label {
  color: #102016;
  font-size: 30rpx;
  font-weight: 800;
}

.menu-hint {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.45;
}

.menu-value {
  flex-shrink: 0;
  color: #0b6b3e;
  font-size: 26rpx;
  font-weight: 850;
}
