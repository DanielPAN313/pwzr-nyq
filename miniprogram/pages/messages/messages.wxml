<view class="page">
  <view class="section">
    <view class="page-title">消息中心</view>
    <text class="muted">后续接入订阅消息、订单提醒、核销提醒和客服通知。</text>
  </view>

  <view wx:for="{{messages}}" wx:key="title" class="section">
    <text class="card-title">{{item.title}}</text>
    <text class="muted">{{item.body}}</text>
  </view>
</view>
