<view class="page">
  <view class="section">
    <view class="page-title">消息中心</view>
    <text wx:if="{{loading}}" class="muted">正在加载消息...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}，已显示本地兜底消息。</text>
    <text wx:elif="{{empty}}" class="muted">暂时没有新消息。</text>
    <text wx:else class="muted">未读 {{unreadCount}} 条。订单、球局和系统通知会在这里汇总。</text>
  </view>

  <view wx:if="{{error}}" class="state-panel warning">
    <text class="state-title">消息数据暂时没连上</text>
    <text class="state-text">当前展示的是本地兜底消息。确认后端运行后可以重试。</text>
    <view class="state-actions">
      <button class="primary small" bindtap="retryLoadMessages">重试加载</button>
      <button class="secondary small" bindtap="goHome">回首页</button>
    </view>
  </view>

  <view wx:elif="{{empty}}" class="state-panel empty">
    <text class="state-title">暂时没有消息</text>
    <text class="state-text">订单支付、核销提醒和球局动态后续都会出现在这里。</text>
    <view class="state-actions">
      <button class="primary small" bindtap="goHome">回首页</button>
      <button class="secondary small" bindtap="goOrders">查看订单</button>
    </view>
  </view>

  <view
    wx:for="{{messageSections}}"
    wx:key="title"
    class="section message-section"
  >
    <view class="section-head">
      <text class="section-title">{{item.title}}</text>
      <text class="section-count">{{item.count}}</text>
    </view>

    <view
      wx:for="{{item.messages}}"
      wx:for-item="message"
      wx:key="id"
      class="message-card message-{{message.statusTone}}"
      bindtap="openMessage"
      data-id="{{message.id}}"
    >
      <view class="message-title-row">
        <text class="card-title">{{message.title}}</text>
        <text class="status-pill status-{{message.statusTone}}">{{message.statusText}}</text>
      </view>
      <text class="muted">{{message.body}}</text>
      <view class="message-footer">
        <text class="target-hint">{{message.actionHint}} · {{message.timeText}}</text>
        <text wx:if="{{message.targetText}}" class="action-text">{{message.targetText}}</text>
      </view>
    </view>
  </view>
</view>
