<view class="page">
  <view class="section page-hero">
    <text class="page-kicker">NOTIFICATIONS</text>
    <view class="page-title">消息中心</view>
    <text wx:if="{{loading}}" class="muted">正在加载消息...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}，已显示本地兜底消息。</text>
    <text wx:elif="{{empty}}" class="muted">暂时没有新消息。</text>
    <text wx:else class="muted">已接入订单提醒、核销提醒和系统通知。</text>
  </view>

  <view
    wx:for="{{messages}}"
    wx:key="title"
    class="section message-card"
    bindtap="markRead"
    data-id="{{item.id}}"
  >
    <view class="message-head">
      <text class="message-dot"></text>
      <text class="card-title">{{item.title}}</text>
    </view>
    <text class="muted">{{item.body}}</text>
    <view class="message-foot">
      <text class="pill">{{item.statusText}}</text>
      <text class="muted">{{item.timeText}}</text>
    </view>
  </view>
</view>
