<view class="page">
  <view class="section">
    <view class="page-title">我的球局</view>
    <text wx:if="{{loading}}" class="muted">正在加载我的球局...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}，已显示本地兜底内容。</text>
    <text wx:elif="{{empty}}" class="muted">暂时没有报名或发起的球局。</text>
    <text wx:else class="muted">这里展示我报名和我发起的球局。</text>
    <view class="action-row">
      <button class="primary small" bindtap="goGames">去报名</button>
      <button class="secondary small" bindtap="createGame">发起球局</button>
    </view>
  </view>

  <view wx:for="{{games}}" wx:key="title" class="section my-game-card">
    <text class="card-title">{{item.title}}</text>
    <text class="muted">{{item.time}} · {{item.venueName}} · {{item.fee}}</text>
    <view class="card-row">
      <text class="role">{{item.roleText}}</text>
      <text class="status">{{item.statusText}}</text>
    </view>
  </view>
</view>
