.page-title,
.card-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 34rpx;
  font-weight: 850;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.action-row button {
  flex: 1;
}

.secondary {
  color: #12824f;
  background: #eef6ed;
}

.my-game-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.role {
  color: #12824f;
  font-size: 26rpx;
  font-weight: 850;
}

.status {
  color: #102016;
  font-size: 26rpx;
  font-weight: 850;
}
