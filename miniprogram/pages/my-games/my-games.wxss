.page-title,
.card-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 34rpx;
  font-weight: 850;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.action-row button {
  flex: 1;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 6rpx;
  padding: 20rpx 16rpx;
  border: 1rpx solid rgba(219, 228, 216, 0.95);
  border-radius: 18rpx;
  background: #ffffff;
}

.stat-value {
  color: #102016;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.tabs {
  display: flex;
  width: 100%;
  margin-bottom: 20rpx;
  white-space: nowrap;
}

.tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 118rpx;
  height: 58rpx;
  margin-right: 12rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(219, 228, 216, 0.95);
  border-radius: 999rpx;
  color: #5c6a61;
  font-size: 26rpx;
  font-weight: 800;
  background: #ffffff;
}

.tab.active {
  color: #ffffff;
  border-color: #12824f;
  background: #12824f;
}

.empty-panel {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.game-section {
  margin-bottom: 8rpx;
}

.section-heading {
  margin: 10rpx 4rpx 16rpx;
  color: #5c6a61;
  font-size: 26rpx;
  font-weight: 850;
}

.secondary {
  color: #12824f;
  background: #eef6ed;
}

.my-game-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-head .card-title {
  flex: 1;
  min-width: 0;
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.role {
  color: #12824f;
  font-size: 26rpx;
  font-weight: 850;
}

.status {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #102016;
  font-size: 24rpx;
  font-weight: 850;
  background: #f3f7f1;
}

.status.success {
  color: #0b6b42;
  background: #e6f6ec;
}

.status.warning {
  color: #925200;
  background: #fff4d6;
}

.status.info {
  color: #116078;
  background: #e5f5f8;
}

.status.muted {
  color: #6b6f69;
  background: #f1f3f0;
}

.progress-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.progress-track {
  position: relative;
  flex: 1;
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e7eee4;
}

.progress-fill {
  height: 100%;
  border-radius: inherit;
  background: #12824f;
}

.joined {
  flex-shrink: 0;
  color: #5c6a61;
  font-size: 24rpx;
  font-weight: 800;
}

.step-box {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f5f8f3;
}

.step-box.success {
  background: #e9f7ee;
}

.step-box.warning {
  background: #fff6df;
}

.step-box.info {
  background: #eaf6f8;
}

.step-title {
  color: #102016;
  font-size: 27rpx;
  font-weight: 900;
}

.step-text {
  color: #5c6a61;
  font-size: 24rpx;
  line-height: 1.5;
}

.mini-action {
  width: 168rpx;
  min-width: 168rpx;
  height: 58rpx;
  padding: 0;
  font-size: 24rpx;
  line-height: 58rpx;
}

@media (max-width: 360px) {
  .stat-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
