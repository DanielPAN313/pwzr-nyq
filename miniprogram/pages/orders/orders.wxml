<view class="page">
  <view class="section">
    <view class="page-title">我的订单</view>
    <text wx:if="{{loading}}" class="muted">正在加载订单...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}，已显示本地兜底订单。</text>
    <text wx:elif="{{empty}}" class="muted">暂时没有订单。去球局页报名后会生成待支付订单。</text>
    <text wx:else class="muted">这里展示报名、订场和到场核销相关订单。</text>
    <text wx:if="{{noticeText}}" class="notice-text">{{noticeText}}</text>
  </view>

  <view
    wx:for="{{orders}}"
    wx:key="id"
    id="{{item.anchorId}}"
    class="section order-card {{item.highlighted ? 'is-highlighted' : ''}}"
  >
    <text class="card-title">{{item.title}}</text>
    <text class="muted">{{item.venueName}} · {{item.timeText}}</text>
    <view class="card-row">
      <text class="price">{{item.amountText}}</text>
      <text class="status">{{item.statusText}}</text>
    </view>
    <view wx:if="{{item.showCheckin}}" class="checkin-box">
      <text class="muted">核销码</text>
      <text class="checkin-code">{{item.checkinCode}}</text>
    </view>
    <text class="muted">{{item.hint}}</text>
    <view wx:if="{{item.canPay || item.canCheckin || item.canCancel}}" class="order-actions">
      <button
        wx:if="{{item.canPay}}"
        class="primary small"
        disabled="{{actionOrderId === item.id}}"
        bindtap="payOrder"
        data-id="{{item.id}}"
      >
        {{actionOrderId === item.id ? "处理中" : "模拟支付"}}
      </button>
      <button
        wx:if="{{item.canCheckin}}"
        class="primary small"
        disabled="{{actionOrderId === item.id}}"
        bindtap="checkinOrder"
        data-id="{{item.id}}"
      >
        {{actionOrderId === item.id ? "处理中" : "模拟核销"}}
      </button>
      <button
        wx:if="{{item.canCancel}}"
        class="secondary small"
        disabled="{{actionOrderId === item.id}}"
        bindtap="cancelOrder"
        data-id="{{item.id}}"
      >
        {{actionOrderId === item.id ? "处理中" : "取消订单"}}
      </button>
    </view>
  </view>
</view>
