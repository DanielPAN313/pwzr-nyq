.page-title,
.section-title,
.card-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 34rpx;
  font-weight: 850;
}

.section-title {
  font-size: 30rpx;
}

.step-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.step-card {
  min-height: 138rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(20, 32, 50, 0.08);
  border-radius: 8rpx;
  background: #f8fafc;
}

.step-title {
  display: block;
  color: #102016;
  font-size: 24rpx;
  font-weight: 850;
}

.step-text {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.45;
}

.section-hint {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.5;
}

.checkin-panel {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.application-panel,
.maintenance-panel {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-input {
  width: 100%;
  height: 76rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(219, 228, 216, 0.95);
  border-radius: 14rpx;
  background: #f8faf7;
  color: #102016;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  min-height: 132rpx;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(219, 228, 216, 0.95);
  border-radius: 14rpx;
  background: #f8faf7;
  color: #102016;
  font-size: 28rpx;
}

.code-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.code-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(219, 228, 216, 0.95);
  border-radius: 14rpx;
  background: #f8faf7;
  color: #102016;
  font-size: 28rpx;
}

.code-button {
  flex-shrink: 0;
  min-width: 132rpx;
}

.result-text {
  color: #0b6b3e;
  font-size: 26rpx;
  font-weight: 750;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.metric-card {
  padding: 24rpx;
  border: 1rpx solid rgba(219, 228, 216, 0.9);
  border-radius: 20rpx;
  background: #ffffff;
}

.metric-value {
  display: block;
  margin-bottom: 8rpx;
  color: #102016;
  font-size: 38rpx;
  font-weight: 900;
}

.venue-row,
.order-row,
.checkin-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.venue-row {
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(219, 228, 216, 0.9);
}

.order-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.order-card.is-highlighted {
  border-color: #12824f;
  box-shadow: 0 12rpx 30rpx rgba(18, 130, 79, 0.16);
}

.price {
  color: #12824f;
  font-size: 34rpx;
  font-weight: 900;
}

.status {
  color: #102016;
  font-size: 26rpx;
  font-weight: 800;
}

.checkin-box {
  padding: 18rpx;
  border-radius: 16rpx;
  background: #eef6ed;
}

.checkin-code {
  color: #102016;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.order-step {
  display: block;
  padding: 16rpx;
  border-left: 6rpx solid #94a3b8;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 750;
}

.order-warning {
  border-left-color: #f97316;
  background: #fff7ed;
  color: #c2410c;
}

.order-info {
  border-left-color: #3b82f6;
  background: #eff6ff;
  color: #1d4ed8;
}

.order-success {
  border-left-color: #12b76a;
  background: #ecfdf3;
  color: #067647;
}

.order-muted {
  border-left-color: #94a3b8;
  background: #f1f5f9;
  color: #64748b;
}
