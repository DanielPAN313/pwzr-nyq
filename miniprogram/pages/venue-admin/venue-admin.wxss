.page-title,
.section-title,
.card-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 34rpx;
  font-weight: 850;
}

.section-title {
  font-size: 30rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.metric-card {
  padding: 24rpx;
  border: 1rpx solid rgba(219, 228, 216, 0.9);
  border-radius: 20rpx;
  background: #ffffff;
}

.metric-value {
  display: block;
  margin-bottom: 8rpx;
  color: #102016;
  font-size: 38rpx;
  font-weight: 900;
}

.venue-row,
.order-row,
.checkin-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.venue-row {
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(219, 228, 216, 0.9);
}

.order-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.price {
  color: #12824f;
  font-size: 34rpx;
  font-weight: 900;
}

.status {
  color: #102016;
  font-size: 26rpx;
  font-weight: 800;
}

.checkin-box {
  padding: 18rpx;
  border-radius: 16rpx;
  background: #eef6ed;
}

.checkin-code {
  color: #102016;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}
