<view class="page">
  <view class="section">
    <view class="page-title">场馆详情</view>
    <text wx:if="{{loading}}" class="muted">正在加载场馆...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}</text>
    <text wx:else class="muted">选择日期和开放时段，生成待支付订单。</text>
  </view>

  <view wx:if="{{error && !venue}}" class="state-panel warning">
    <text class="state-title">场馆详情暂时不可用</text>
    <text class="state-text">{{error}} 可以重新加载当前日期，或者返回订场页换一个场馆。</text>
    <view class="state-actions">
      <button class="primary small" bindtap="retryLoadAvailability">重试加载</button>
      <button class="secondary small" bindtap="goVenues">返回订场</button>
    </view>
  </view>

  <block wx:if="{{venue}}">
    <view class="venue-hero">
      <text class="venue-title">{{venue.name}}</text>
      <text class="venue-tag">{{venue.indoorText}} · {{venue.sportsText}}</text>
      <text class="venue-muted">{{venue.area}} · {{venue.priceText}}</text>
    </view>

    <view class="section">
      <view class="section-title">场馆信息</view>
      <view class="detail-grid">
        <view wx:for="{{venue.detailCards}}" wx:key="label" class="detail-card">
          <text class="detail-value">{{item.value}}</text>
          <text class="detail-label">{{item.label}}</text>
        </view>
      </view>
      <text class="muted">{{venue.address}}</text>
      <view class="slot-summary">
        <text class="slot-summary-title">开放时段</text>
        <text class="slot-summary-text">{{venue.openSlotsText}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-title">选择日期</view>
      <picker mode="date" value="{{date}}" start="{{minDate}}" bindchange="changeDate">
        <view class="picker-value">{{date}}</view>
      </picker>
    </view>

    <view class="section">
      <view class="section-title">开放时段</view>
      <view wx:if="{{slots.length === 0}}" class="state-panel empty">
        <text class="state-title">当天暂无可选时段</text>
        <text class="state-text">可以切换日期重新查看，或返回订场页选择其他场馆。</text>
        <view class="state-actions">
          <button class="primary small" bindtap="retryLoadAvailability">重新加载</button>
          <button class="secondary small" bindtap="goVenues">换个场馆</button>
        </view>
      </view>
      <view
        wx:for="{{slots}}"
        wx:key="id"
        class="slot-row {{selectedSlotIndex === index ? 'selected' : ''}} {{item.occupied ? 'disabled' : ''}}"
        bindtap="selectSlot"
        data-index="{{index}}"
      >
        <text>{{item.label}}</text>
        <text class="slot-status slot-{{item.statusTone}}">{{item.statusText}}</text>
      </view>
    </view>

    <view class="section booking-summary">
      <view>
        <text class="summary-label">当前选择</text>
        <text class="summary-value">{{selectedSlotLabel}}</text>
      </view>
      <text class="summary-status">{{selectedSlotStatusText}}</text>
    </view>

    <button
      class="primary submit-button"
      disabled="{{!canSubmitBooking || bookingSlotId}}"
      bindtap="bookSelectedSlot"
    >
      {{bookingSlotId ? "锁定中" : "生成待支付订单"}}
    </button>
  </block>
</view>
