.page-title,
.section-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 34rpx;
  font-weight: 850;
}

.venue-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 34rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: #064327;
}

.venue-title {
  font-size: 42rpx;
  font-weight: 900;
}

.venue-tag {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #083923;
  background: #d7f36a;
  font-size: 24rpx;
  font-weight: 850;
}

.venue-muted {
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.detail-card {
  min-height: 108rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(20, 32, 50, 0.08);
  border-radius: 8rpx;
  background: #f8fafc;
}

.detail-value {
  display: block;
  color: #102016;
  font-size: 26rpx;
  font-weight: 850;
  word-break: break-all;
}

.detail-label {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 750;
}

.picker-value {
  min-height: 78rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #eef6ed;
  color: #102016;
  font-size: 28rpx;
  box-sizing: border-box;
}

.slot-summary {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f8fafc;
}

.slot-summary-title {
  color: #102016;
  font-size: 26rpx;
  font-weight: 850;
}

.slot-summary-text {
  color: #475569;
  font-size: 24rpx;
  line-height: 1.5;
}

.slot-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 14rpx;
  padding: 20rpx;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  background: #eef6ed;
  color: #102016;
  font-size: 28rpx;
  font-weight: 800;
}

.slot-row.selected {
  border-color: #12824f;
  background: #e4f6e9;
}

.slot-row.disabled {
  opacity: 0.48;
}

.slot-status {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 850;
}

.slot-available {
  background: #dcfce7;
  color: #067647;
}

.slot-disabled {
  background: #e2e8f0;
  color: #64748b;
}

.booking-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-left: 6rpx solid #12b76a;
  background: #ecfdf3;
}

.summary-label,
.summary-status {
  display: block;
  color: #067647;
  font-size: 24rpx;
  font-weight: 750;
}

.summary-value {
  display: block;
  margin-top: 6rpx;
  color: #102016;
  font-size: 30rpx;
  font-weight: 900;
}

.summary-status {
  flex-shrink: 0;
  text-align: right;
}

.submit-button {
  margin-top: 8rpx;
  min-height: 88rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 850;
}
