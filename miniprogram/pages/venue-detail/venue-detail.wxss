.page-title,
.section-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 34rpx;
  font-weight: 850;
}

.venue-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 34rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: #064327;
}

.venue-title {
  font-size: 42rpx;
  font-weight: 900;
}

.venue-tag {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #083923;
  background: #d7f36a;
  font-size: 24rpx;
  font-weight: 850;
}

.venue-muted {
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
}

.picker-value {
  min-height: 78rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #eef6ed;
  color: #102016;
  font-size: 28rpx;
  box-sizing: border-box;
}

.slot-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 14rpx;
  padding: 20rpx;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  background: #eef6ed;
  color: #102016;
  font-size: 28rpx;
  font-weight: 800;
}

.slot-row.selected {
  border-color: #12824f;
  background: #e4f6e9;
}

.slot-row.disabled {
  opacity: 0.48;
}

.submit-button {
  margin-top: 8rpx;
  min-height: 88rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 850;
}
