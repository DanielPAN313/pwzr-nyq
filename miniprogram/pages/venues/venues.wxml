<view class="page">
  <view class="section page-hero">
    <text class="page-kicker">COURTS NEARBY</text>
    <view class="page-title">附近可订场馆</view>
    <text wx:if="{{loading}}" class="muted">正在加载场馆...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}，已显示本地兜底场馆。</text>
    <text wx:elif="{{empty}}" class="muted">暂时没有可订场馆。</text>
    <text wx:else class="muted">已接入真实场馆列表，后续继续补筛选和预订支付。</text>
    <view class="filter-row">
      <text class="pill dark">附近</text>
      <text class="pill">今晚可订</text>
      <text class="pill">篮球 / 足球</text>
    </view>
  </view>

  <view wx:for="{{venues}}" wx:key="name" class="section venue-card">
    <view class="venue-visual">
      <view class="court-grid"></view>
      <text class="visual-tag">{{item.sportsText}}</text>
    </view>
    <view class="card-top">
      <view>
        <text class="card-title">{{item.name}}</text>
        <text class="muted">{{item.area}} · {{item.sportsText}}</text>
      </view>
      <text class="rating">4.8</text>
    </view>
    <view class="card-row">
      <view>
        <text class="price">¥{{item.price}}</text>
        <text class="muted">黄金时段优先锁场</text>
      </view>
      <button class="primary small">订场</button>
    </view>
  </view>
</view>
