<view class="page">
  <view class="section">
    <view class="page-title">附近可订场馆</view>
    <text wx:if="{{loading}}" class="muted">正在加载场馆...</text>
    <text wx:elif="{{error}}" class="muted">{{error}}，已显示本地兜底场馆。</text>
    <text wx:elif="{{empty}}" class="muted">暂时没有可订场馆。</text>
    <text wx:else class="muted">已接入真实场馆列表，后续继续补筛选和预订支付。</text>
  </view>

  <view wx:for="{{venues}}" wx:key="name" class="section venue-card" bindtap="openVenue" data-id="{{item.id}}">
    <text class="card-title">{{item.name}}</text>
    <text class="muted">{{item.area}} · {{item.sportsText}}</text>
    <text class="muted">默认时段：{{item.bookingLabel}}</text>
    <view class="card-row">
      <text class="price">¥{{item.price}}</text>
      <button
        class="primary small"
        disabled="{{!item.canBook || bookingVenueId === item.id}}"
        catchtap="bookVenue"
        data-id="{{item.id}}"
      >
        {{bookingVenueId === item.id ? "锁定中" : item.actionText}}
      </button>
    </view>
  </view>
</view>
